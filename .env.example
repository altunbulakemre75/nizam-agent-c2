# NIZAM COP — environment configuration
# Copy to .env and edit before production deployment.

# ── Ports ────────────────────────────────────────────────────
COP_PORT=8100
ORCH_PORT=8200

# ── PostgreSQL / TimescaleDB ──────────────────────────────────
# Leave DATABASE_URL empty to run without a database (in-memory only).
# With Docker Compose, use the service name "db":
DATABASE_URL=postgresql+asyncpg://nizam:nizam@db:5432/nizam

# ── Authentication ────────────────────────────────────────────
# Set to "true" to enforce JWT login on all write endpoints.
AUTH_ENABLED=false

# Change this in production! Used to sign JWT tokens.
JWT_SECRET=nizam-dev-secret-CHANGE-in-production

# Token lifetime in minutes (default 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# API key for /ingest endpoint (required when AUTH_ENABLED=true).
# Pipeline agents (cop_publisher) must send this as X-API-Key header.
# Leave empty to allow unauthenticated ingest (dev mode).
INGEST_API_KEY=

# ── Orchestrator ──────────────────────────────────────────────
ORCHESTRATOR_URL=http://orchestrator:8200

# ── AI Decision Support (Phase 5) ────────────────────────────
# LLM provider: "anthropic", "openai", or "ollama" (default: anthropic)
# Ollama is free and runs locally — recommended for development.
LLM_PROVIDER=ollama

# Cloud API keys (only needed if LLM_PROVIDER is anthropic or openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama settings (only needed if LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2

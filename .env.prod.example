# ─────────────────────────────────────────────────────────────────────────────
#  NIZAM COP — Production environment configuration
#  Copy to .env and fill in ALL values before running docker-compose.prod.yml
#
#  SECURITY CHECKLIST before deployment:
#    [ ] JWT_SECRET  — 32+ random characters, never reuse dev value
#    [ ] DB_PASSWORD — strong password, not "nizam"
#    [ ] INGEST_API_KEY — random token for sensor adapters
#    [ ] TLS certs placed in nginx/certs/  (see nginx/certs/.gitkeep)
#    [ ] Firewall: only ports 80/443/1883 accessible from intended networks
#    [ ] AUTH_ENABLED must be "true" in production
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports ─────────────────────────────────────────────────────────────────
COP_PORT=8100
ORCH_PORT=8200

# ── PostgreSQL / TimescaleDB ───────────────────────────────────────────────
# These must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in db service.
DB_USER=nizam
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=nizam
DATABASE_URL=postgresql+asyncpg://nizam:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/nizam

# ── Authentication ────────────────────────────────────────────────────────
# MUST be true in production.
AUTH_ENABLED=true

# Minimum 32 random characters.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_REPLACE_WITH_32_RANDOM_CHARS

# Token lifetime in minutes (8 hours default)
JWT_EXPIRE_MINUTES=480

# API key for sensor adapters hitting /ingest.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=CHANGE_ME_SENSOR_API_KEY

# ── Node identity ─────────────────────────────────────────────────────────
NODE_ID=cop-node-01

# ── Orchestrator ──────────────────────────────────────────────────────────
ORCHESTRATOR_URL=http://orchestrator:8200

# ── CoT / TAK adapter ─────────────────────────────────────────────────────
# UDP multicast group ATAK devices broadcast SA to (standard: 239.2.3.1)
COT_MCAST_GROUP=239.2.3.1
COT_UDP_PORT=4242

# ── MQTT broker ───────────────────────────────────────────────────────────
# Topic the mqtt_adapter subscribes to
MQTT_TOPIC=nizam/tracks

# ── Outbound Webhooks ─────────────────────────────────────────────────────
# Comma-separated URLs to POST alerts to (HIGH threat, zone breach, EW).
# Leave empty to disable.
WEBHOOK_URL=

# ── Rate limiting ─────────────────────────────────────────────────────────
# Max write requests (POST/PUT/DELETE) per IP per window
RATE_LIMIT_WRITES=200
RATE_LIMIT_WINDOW_S=60

# ── AI Decision Support ────────────────────────────────────────────────────
# "anthropic", "openai", or "ollama"
LLM_PROVIDER=ollama

# Cloud API keys (only if LLM_PROVIDER != ollama)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama endpoint (must be reachable from Docker network)
# On the same host: http://host.docker.internal:11434
OLLAMA_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2

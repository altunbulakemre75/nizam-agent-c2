# Vendor repos (89 reference repos, ~3GB — local only, use clone_vendors.sh)
vendor/

# mTLS cert'leri — asla git'e girmesin
infra/certs/
*.key
*.p12
*.pem

# NATS nkey seed'leri — asla git'e girmesin
infra/nats/*.nk
infra/nats/.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
.venv/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Env
.env

# Docker
*.tar

# Test cache
.pytest_cache/

# Alembic
alembic/versions/*.pyc

# Generated runtime artefacts
recordings/
reports/

# TLS certs (never commit private keys)
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.pem
mosquitto/certs/
